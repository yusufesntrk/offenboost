---
const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/leistungen', label: 'Leistungen' },
  { href: '/ueber-uns', label: 'Über uns' },
  { href: '/casestudies', label: 'Case Studies' },
  { href: '/blog', label: 'Blog' },
];

const branchenLinks = [
  { href: '/personaldienstleister', label: 'Personaldienstleister' },
  { href: '/kanzleien', label: 'Kanzleien' },
  { href: '/fahrschulen', label: 'Fahrschulen' },
  { href: '/praxen', label: 'Praxen' },
  { href: '/finanzdienstleister', label: 'Finanzdienstleister' },
  { href: '/restaurants', label: 'Restaurants' },
];

const isBranchenActive = branchenLinks.some(link => pathname.startsWith(link.href));

function isActive(href: string): boolean {
  if (href === '/') {
    return pathname === '/';
  }
  return pathname.startsWith(href);
}
---

<nav class="w-full py-4 px-4 md:px-8 sticky top-0 z-50 bg-background/80 backdrop-blur-lg" aria-label="Hauptnavigation">
  <div class="max-w-6xl mx-auto">
    <div class="flex items-center justify-between bg-card rounded-2xl px-6 py-3 shadow-card border border-border/50">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 min-h-[44px]" aria-label="OffenBoost Startseite">
        <div class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-white">
            <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/>
            <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>
            <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/>
            <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>
          </svg>
        </div>
        <span class="font-bold text-lg text-secondary">
          Offen<span class="text-primary">Boost</span>
        </span>
      </a>

      <!-- Navigation Links -->
      <div class="hidden md:flex items-center gap-2">
        {navLinks.slice(0, 2).map((link) => (
          <a
            href={link.href}
            class={isActive(link.href) ? 'nav-link-active' : 'nav-link'}
          >
            {link.label}
          </a>
        ))}

        <!-- Branchen Dropdown -->
        <div class="relative" id="branchen-dropdown">
          <button
            type="button"
            class:list={[
              'flex items-center gap-1 px-3 py-2 rounded-lg text-sm font-medium transition-colors cursor-pointer',
              isBranchenActive
                ? 'bg-primary/10 text-primary'
                : 'text-muted-foreground hover:text-foreground hover:bg-muted',
            ]}
            id="branchen-trigger"
            aria-expanded="false"
            aria-haspopup="true"
          >
            Branchen
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform" id="branchen-chevron">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </button>
          <div
            id="branchen-panel"
            class="absolute top-full left-0 mt-2 w-56 bg-card rounded-xl border border-border/50 shadow-xl py-2 opacity-0 invisible transition-all duration-200 z-50"
          >
            {branchenLinks.map((link) => (
              <a
                href={link.href}
                class:list={[
                  'block px-4 py-2.5 text-sm font-medium transition-colors',
                  isActive(link.href)
                    ? 'bg-primary/10 text-primary'
                    : 'text-secondary hover:bg-muted hover:text-foreground',
                ]}
              >
                {link.label}
              </a>
            ))}
          </div>
        </div>

        {navLinks.slice(2).map((link) => (
          <a
            href={link.href}
            class={isActive(link.href) ? 'nav-link-active' : 'nav-link'}
          >
            {link.label}
          </a>
        ))}
      </div>

      <!-- CTA Button (Desktop) -->
      <a
        href="/termin"
        class="hidden md:inline-flex items-center justify-center gap-2 whitespace-nowrap font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring bg-primary text-primary-foreground shadow hover:bg-primary/90 h-9 rounded-full px-4 text-sm"
      >
        Erstgespräch
      </a>

      <!-- Hamburger Button (Mobile) -->
      <button
        id="mobile-menu-toggle"
        type="button"
        class="md:hidden flex items-center justify-center w-10 h-10 rounded-lg text-secondary hover:bg-muted transition-colors"
        aria-label="Menü öffnen"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <!-- Hamburger Icon -->
        <svg id="icon-hamburger" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" y1="6" x2="20" y2="6" />
          <line x1="4" y1="12" x2="20" y2="12" />
          <line x1="4" y1="18" x2="20" y2="18" />
        </svg>
        <!-- Close Icon (hidden by default) -->
        <svg id="icon-close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18" />
          <line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>

    <!-- Mobile Menu Drawer -->
    <div
      id="mobile-menu"
      class="md:hidden overflow-hidden transition-all duration-300 ease-in-out"
      style="max-height: 0; opacity: 0;"
    >
      <div class="flex flex-col gap-1 pt-3 pb-4 px-2">
        {navLinks.slice(0, 2).map((link) => (
          <a
            href={link.href}
            class:list={[
              'mobile-nav-link block rounded-xl px-4 py-3 text-base font-medium transition-colors',
              isActive(link.href)
                ? 'bg-primary/10 text-primary'
                : 'text-secondary hover:bg-muted',
            ]}
          >
            {link.label}
          </a>
        ))}

        <!-- Branchen (Mobile) -->
        <div>
          <button
            type="button"
            id="mobile-branchen-toggle"
            class:list={[
              'w-full flex items-center justify-between rounded-xl px-4 py-3 text-base font-medium transition-colors cursor-pointer',
              isBranchenActive
                ? 'bg-primary/10 text-primary'
                : 'text-secondary hover:bg-muted',
            ]}
          >
            Branchen
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform" id="mobile-branchen-chevron">
              <path d="m6 9 6 6 6-6"/>
            </svg>
          </button>
          <div id="mobile-branchen-list" class="overflow-hidden transition-all duration-300" style="max-height: 0; opacity: 0;">
            <div class="pl-4 flex flex-col gap-1 pt-1">
              {branchenLinks.map((link) => (
                <a
                  href={link.href}
                  class:list={[
                    'mobile-nav-link block rounded-xl px-4 py-2.5 text-sm font-medium transition-colors',
                    isActive(link.href)
                      ? 'bg-primary/10 text-primary'
                      : 'text-muted-foreground hover:bg-muted hover:text-secondary',
                  ]}
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </div>

        {navLinks.slice(2).map((link) => (
          <a
            href={link.href}
            class:list={[
              'mobile-nav-link block rounded-xl px-4 py-3 text-base font-medium transition-colors',
              isActive(link.href)
                ? 'bg-primary/10 text-primary'
                : 'text-secondary hover:bg-muted',
            ]}
          >
            {link.label}
          </a>
        ))}
        <div class="pt-2 px-2">
          <a
            href="/termin"
            class="mobile-nav-link block w-full text-center rounded-full bg-primary text-primary-foreground font-medium py-3 px-4 shadow hover:bg-primary/90 transition-colors"
          >
            Erstgespräch
          </a>
        </div>
      </div>
    </div>
  </div>
</nav>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const iconHamburger = document.getElementById('icon-hamburger');
    const iconClose = document.getElementById('icon-close');
    const mobileLinks = menu?.querySelectorAll('.mobile-nav-link');

    if (!toggle || !menu || !iconHamburger || !iconClose) return;

    let isOpen = false;

    function openMenu() {
      isOpen = true;
      menu.style.maxHeight = menu.scrollHeight + 'px';
      menu.style.opacity = '1';
      toggle.setAttribute('aria-expanded', 'true');
      toggle.setAttribute('aria-label', 'Menü schließen');
      iconHamburger.classList.add('hidden');
      iconClose.classList.remove('hidden');
    }

    function closeMenu() {
      isOpen = false;
      menu.style.maxHeight = '0';
      menu.style.opacity = '0';
      toggle.setAttribute('aria-expanded', 'false');
      toggle.setAttribute('aria-label', 'Menü öffnen');
      iconHamburger.classList.remove('hidden');
      iconClose.classList.add('hidden');
    }

    toggle.addEventListener('click', () => {
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    mobileLinks?.forEach((link) => {
      link.addEventListener('click', () => {
        closeMenu();
      });
    });

    // Desktop Branchen Dropdown
    var branchenDropdown = document.getElementById('branchen-dropdown');
    var branchenTrigger = document.getElementById('branchen-trigger');
    var branchenPanel = document.getElementById('branchen-panel');
    var branchenChevron = document.getElementById('branchen-chevron');

    if (branchenDropdown && branchenTrigger && branchenPanel) {
      var dropdownOpen = false;

      function showDropdown() {
        dropdownOpen = true;
        branchenPanel.style.opacity = '1';
        branchenPanel.style.visibility = 'visible';
        branchenPanel.style.transform = 'translateY(0)';
        if (branchenChevron) branchenChevron.style.transform = 'rotate(180deg)';
        branchenTrigger.setAttribute('aria-expanded', 'true');
      }

      function hideDropdown() {
        dropdownOpen = false;
        branchenPanel.style.opacity = '0';
        branchenPanel.style.visibility = 'hidden';
        branchenPanel.style.transform = 'translateY(-4px)';
        if (branchenChevron) branchenChevron.style.transform = 'rotate(0deg)';
        branchenTrigger.setAttribute('aria-expanded', 'false');
      }

      branchenPanel.style.transform = 'translateY(-4px)';

      branchenDropdown.addEventListener('mouseenter', showDropdown);
      branchenDropdown.addEventListener('mouseleave', hideDropdown);

      branchenTrigger.addEventListener('click', function() {
        if (dropdownOpen) { hideDropdown(); } else { showDropdown(); }
      });

      document.addEventListener('click', function(e) {
        if (!branchenDropdown.contains(e.target)) hideDropdown();
      });
    }

    // Mobile Branchen Toggle
    var mobileBranchenToggle = document.getElementById('mobile-branchen-toggle');
    var mobileBranchenList = document.getElementById('mobile-branchen-list');
    var mobileBranchenChevron = document.getElementById('mobile-branchen-chevron');

    if (mobileBranchenToggle && mobileBranchenList) {
      var mobileBranchenOpen = false;

      mobileBranchenToggle.addEventListener('click', function() {
        mobileBranchenOpen = !mobileBranchenOpen;
        if (mobileBranchenOpen) {
          mobileBranchenList.style.maxHeight = mobileBranchenList.scrollHeight + 'px';
          mobileBranchenList.style.opacity = '1';
          if (mobileBranchenChevron) mobileBranchenChevron.style.transform = 'rotate(180deg)';
          // Recalculate parent menu height
          if (menu) menu.style.maxHeight = menu.scrollHeight + mobileBranchenList.scrollHeight + 'px';
        } else {
          mobileBranchenList.style.maxHeight = '0';
          mobileBranchenList.style.opacity = '0';
          if (mobileBranchenChevron) mobileBranchenChevron.style.transform = 'rotate(0deg)';
        }
      });
    }
  });
</script>
