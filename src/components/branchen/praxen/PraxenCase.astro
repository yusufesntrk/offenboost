---
---

<section class="bg-secondary text-secondary-foreground py-16 md:py-24 px-4 md:px-8">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-primary font-medium mb-4">Case Study</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white tracking-tight">
        Zahnärzte im Seerheincenter, Konstanz
      </h2>
    </div>

    <!-- Content Grid -->
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- LEFT: Image -->
      <div>
        <div class="relative rounded-2xl overflow-hidden">
          <img
            src="/testimonials/dr-schmidt.jpg"
            alt="Dr. Schmidt, Zahnarzt & Inhaber"
            class="w-full h-auto rounded-2xl"
            loading="lazy"
          />
        </div>
        <div class="flex items-center gap-3 mt-4">
          <span class="text-sm text-secondary-foreground/70">Dr. Schmidt, Zahnarzt &amp; Inhaber</span>
        </div>
      </div>

      <!-- RIGHT: Content -->
      <div>
        <!-- Vorher -->
        <div class="rounded-xl p-5 bg-white/5 border border-white/10 mb-4">
          <p class="text-xs font-medium uppercase tracking-wider text-destructive mb-2">Vorher</p>
          <ul class="text-secondary-foreground/80 text-sm list-disc pl-4 space-y-1">
            <li>Wenig Online-Sichtbarkeit</li>
            <li>Telefon ständig besetzt, Patienten springen ab</li>
            <li>Verwaltungsaufwand frisst Behandlungszeit</li>
          </ul>
        </div>

        <!-- Nachher -->
        <div class="rounded-xl p-5 bg-primary/10 border border-primary/20 mb-6">
          <p class="text-xs font-medium uppercase tracking-wider text-primary mb-2">Nachher</p>
          <ul class="text-secondary-foreground/90 text-sm font-medium list-disc pl-4 space-y-1">
            <li>KI-Telefonassistent beantwortet 80% der Anrufe</li>
            <li>Online-Terminbuchung spart 15h/Woche</li>
            <li>+140% Neupatientenanfragen</li>
          </ul>
        </div>

        <!-- Metric Badge -->
        <div class="mb-6">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/20 text-primary font-bold">
            +140% Neupatientenanfragen &#8593;
          </span>
        </div>

        <!-- Quote -->
        <blockquote class="text-lg text-secondary-foreground/90 italic border-l-4 border-primary pl-4">
          Durch OffenBoost haben wir nicht nur deutlich mehr Patienten gewonnen, sondern auch unsere komplette Praxisverwaltung automatisiert. Telefonassistent, Online-Anmeldung, E-Mail-Automation — wir sparen Stunden an Bürokratie jeden Tag.
          <cite class="block mt-2 text-sm text-secondary-foreground/60 not-italic">— Dr. Schmidt, Zahnarzt &amp; Inhaber</cite>
        </blockquote>
      </div>
    </div>
  </div>
</section>
