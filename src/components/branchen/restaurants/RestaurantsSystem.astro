---
const steps = [
  {
    number: "01",
    title: "Restaurant-Analyse",
    description: "Wir analysieren deine Online-Sichtbarkeit, Bewertungen und Konkurrenz.",
  },
  {
    number: "02",
    title: "Online-Präsenz",
    description: "Google Business Profil optimieren, Social-Media-Strategie aufsetzen.",
  },
  {
    number: "03",
    title: "Bewertungs-Strategie",
    description: "Automatisierte Bewertungsanfragen für ein Top-Google-Rating.",
  },
  {
    number: "04",
    title: "Reservierungs-Optimierung",
    description: "Online-Buchung und lokale Ads für maximale Auslastung.",
  },
  {
    number: "05",
    title: "Stammkunden-System",
    description: "E-Mail-Marketing und Social Media für wiederkehrende Gäste.",
  },
];
---

<section class="py-16 md:py-24 px-4 md:px-8">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <p class="text-primary font-medium mb-4">So funktioniert's</p>
      <h2 class="section-heading mb-4">
        Das OffenBoost Restaurant-System <span class="gradient-text">in 5 Schritten</span>
      </h2>
      <p class="section-subheading mx-auto">
        Ein erprobtes System, das Baldner's Gasthof Schwanen 210% mehr Online-Reservierungen gebracht hat.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid md:grid-cols-5 gap-8">
      {steps.map((step, index) => (
        <div
          class="text-center animate-fade-in-up relative"
          style={`animation-delay: ${index * 150}ms`}
        >
          <!-- Connector Line (hidden on mobile and last item) -->
          {index < steps.length - 1 && (
            <div class="hidden md:block absolute top-8 left-[60%] w-[80%] h-[2px] bg-gradient-to-r from-primary/30 to-transparent" />
          )}

          <div class="text-5xl font-bold text-primary/20 mb-4">
            {step.number}
          </div>
          <h3 class="text-lg font-semibold text-foreground mb-2">
            {step.title}
          </h3>
          <p class="text-sm text-muted-foreground">
            {step.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
