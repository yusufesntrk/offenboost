---
---

<section class="bg-secondary text-secondary-foreground py-16 md:py-24 px-4 md:px-8">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-primary font-medium mb-4">Case Study</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white tracking-tight">
        Baldner's Gasthof Schwanen, Kehl
      </h2>
    </div>

    <!-- Content Grid -->
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- LEFT: Initials Fallback -->
      <div>
        <div class="relative rounded-2xl overflow-hidden aspect-[4/3] bg-gradient-to-br from-primary/30 to-primary/10 flex items-center justify-center">
          <span class="text-8xl font-bold text-white/30">FB</span>
        </div>
        <div class="flex items-center gap-3 mt-4">
          <span class="text-sm text-secondary-foreground/70">Dr. Frieder Baldner, Inhaber</span>
        </div>
      </div>

      <!-- RIGHT: Content -->
      <div>
        <!-- Vorher -->
        <div class="rounded-xl p-5 bg-white/5 border border-white/10 mb-4">
          <p class="text-xs font-medium uppercase tracking-wider text-destructive mb-2">Vorher</p>
          <ul class="text-secondary-foreground/80 text-sm list-disc pl-4 space-y-1">
            <li>Google-Sichtbarkeit auf Seite 3</li>
            <li>Keine Online-Reservierungsmöglichkeit</li>
            <li>Kaum Neugäste unter der Woche</li>
          </ul>
        </div>

        <!-- Nachher -->
        <div class="rounded-xl p-5 bg-primary/10 border border-primary/20 mb-6">
          <p class="text-xs font-medium uppercase tracking-wider text-primary mb-2">Nachher</p>
          <ul class="text-secondary-foreground/90 text-sm font-medium list-disc pl-4 space-y-1">
            <li>Position 1 für "Restaurant Kehl" auf Google</li>
            <li>Online-Reservierungen um 210% gesteigert</li>
            <li>35% mehr Laufkundschaft durch Social Media</li>
          </ul>
        </div>

        <!-- Metric Badge -->
        <div class="mb-6">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/20 text-primary font-bold">
            +210% Reservierungen &#8593;
          </span>
        </div>

        <!-- Quote -->
        <blockquote class="text-lg text-secondary-foreground/90 italic border-l-4 border-primary pl-4">
          Seit über 200 Jahren führen wir den Gasthof Schwanen in fünfter Generation. Mit OffenBoost haben wir den Sprung ins digitale Zeitalter geschafft — unsere Online-Reservierungen haben sich verdreifacht und wir erreichen endlich auch die jüngere Zielgruppe.
          <cite class="block mt-2 text-sm text-secondary-foreground/60 not-italic">— Dr. Frieder Baldner, Inhaber</cite>
        </blockquote>
      </div>
    </div>

    <!-- Additional Testimonial -->
    <div class="mt-16">
      <h3 class="text-xl font-semibold text-white text-center mb-8">Weitere Erfolgsgeschichten</h3>
      <div class="max-w-md mx-auto">
        <div class="bg-white/5 border border-white/10 rounded-xl p-5">
          <div class="flex items-center gap-3 mb-3">
            <img
              src="/testimonials/hasan-kaya.jpg"
              alt="Hasan Kaya"
              class="w-10 h-10 rounded-full object-cover"
              loading="lazy"
            />
            <div>
              <p class="font-semibold text-white text-sm">Hasan Kaya</p>
              <p class="text-secondary-foreground/60 text-xs">DeDi's Tantuni &amp; Grill</p>
            </div>
          </div>
          <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full bg-primary/20 text-primary text-xs font-bold mb-2">+60 Google-Bewertungen &#8593;</span>
          <p class="text-secondary-foreground/80 text-sm italic">"Als kleiner Imbiss in Offenburg hatten wir null Online-Präsenz. OffenBoost hat uns innerhalb von 3 Monaten auf 5 Sterne bei Google gebracht."</p>
        </div>
      </div>
    </div>
  </div>
</section>
