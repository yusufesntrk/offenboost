---
const steps = [
  {
    number: "01",
    title: "Kanzlei-Analyse",
    description: "Wir analysieren deine Mandantenstruktur, Gewinnmarge und Personalkapazität.",
  },
  {
    number: "02",
    title: "Mandanten-Profiling",
    description: "Wir definieren dein ideales Mandantenprofil für maximale Profitabilität.",
  },
  {
    number: "03",
    title: "Recruiting & Marketing",
    description: "Parallele Kampagnen für Fachkräfte-Gewinnung und Premium-Mandate.",
  },
  {
    number: "04",
    title: "Qualifizierung",
    description: "Nur A-Mandate und passende Bewerber landen auf deinem Schreibtisch.",
  },
  {
    number: "05",
    title: "Skalierung",
    description: "Mehr Kapazität, bessere Mandate, höhere Marge — Monat für Monat.",
  },
];
---

<section class="py-16 md:py-24 px-4 md:px-8">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <p class="text-primary font-medium mb-4">So funktioniert's</p>
      <h2 class="section-heading mb-4">
        Das OffenBoost Kanzlei-System <span class="gradient-text">in 5 Schritten</span>
      </h2>
      <p class="section-subheading mx-auto">
        Ein erprobtes System, das über 17 Kanzleien zu höheren Gewinnen und Top-Fachkräften verholfen hat.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid md:grid-cols-5 gap-8">
      {steps.map((step, index) => (
        <div
          class="text-center animate-fade-in-up relative"
          style={`animation-delay: ${index * 150}ms`}
        >
          <!-- Connector Line (hidden on mobile and last item) -->
          {index < steps.length - 1 && (
            <div class="hidden md:block absolute top-8 left-[60%] w-[80%] h-[2px] bg-gradient-to-r from-primary/30 to-transparent" />
          )}

          <div class="text-5xl font-bold text-primary/20 mb-4">
            {step.number}
          </div>
          <h3 class="text-lg font-semibold text-foreground mb-2">
            {step.title}
          </h3>
          <p class="text-sm text-muted-foreground">
            {step.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
