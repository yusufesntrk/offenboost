---
---

<section class="py-16 md:py-24 px-4 md:px-8">
  <div class="max-w-6xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <p class="text-primary font-medium mb-4">Unser Angebot</p>
      <h2 class="section-heading mb-4">
        Kein Risiko. <span class="gradient-text">Nur Ergebnisse.</span>
      </h2>
      <p class="section-subheading mx-auto">
        Mehr Gewinn, bessere Mandate, Top-Fachkräfte.
      </p>
    </div>

    <!-- Offer Cards -->
    <div class="grid md:grid-cols-3 gap-6 max-w-4xl mx-auto mt-12">
      <!-- Card 1: Ergebnisorientiert -->
      <div class="feature-card text-center">
        <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
          <!-- Percent icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
            <line x1="19" y1="5" x2="5" y2="19"/>
            <circle cx="6.5" cy="6.5" r="2.5"/>
            <circle cx="17.5" cy="17.5" r="2.5"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-foreground mb-2">Ergebnisorientiert</h3>
        <p class="text-sm text-muted-foreground">
          Du zahlst für Ergebnisse, nicht für Versprechen. Kein Risiko für dich.
        </p>
      </div>

      <!-- Card 2: Recruiting & Mandanten -->
      <div class="feature-card text-center">
        <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
          <!-- Target icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
            <circle cx="12" cy="12" r="10"/>
            <circle cx="12" cy="12" r="6"/>
            <circle cx="12" cy="12" r="2"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-foreground mb-2">Recruiting &amp; Mandanten</h3>
        <p class="text-sm text-muted-foreground">
          Fachkräfte-Gewinnung und Premium-Mandate aus einem System.
        </p>
      </div>

      <!-- Card 3: Erste Ergebnisse (highlighted) -->
      <div class="feature-card text-center ring-2 ring-primary/20">
        <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center mx-auto mb-4">
          <!-- Clock icon -->
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </div>
        <h3 class="text-lg font-semibold text-foreground mb-2">Erste Ergebnisse in 4 Wochen</h3>
        <p class="text-sm text-muted-foreground">
          Erste Bewerbungen und Mandantenanfragen oft schon nach 2–4 Wochen.
        </p>
      </div>
    </div>

    <!-- Scarcity + CTA -->
    <div class="text-center mt-8">
      <span class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-warning/10 border border-warning/20 text-warning font-medium text-sm">
        &#9889; Wir nehmen aktuell nur 5 neue Kanzleien auf
      </span>
      <div class="mt-6">
        <a
          href="/termin"
          class="inline-flex items-center justify-center gap-2 font-medium bg-primary text-primary-foreground shadow hover:bg-primary/90 h-12 rounded-full px-8 text-base transition-colors"
        >
          Erstgespräch buchen
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
