---
---

<section class="relative min-h-screen flex items-center justify-center px-4 md:px-8 overflow-hidden">
  <!-- Animated Background -->
  <div class="absolute inset-0 pointer-events-none">
    <!-- Gradient Orbs -->
    <div
      class="absolute top-0 right-0 w-[300px] h-[300px] md:w-[600px] md:h-[600px] rounded-full opacity-30"
      style="background: radial-gradient(circle, hsl(var(--primary) / 0.15) 0%, transparent 70%);"
    />
    <div
      class="absolute bottom-0 left-0 w-[250px] h-[250px] md:w-[500px] md:h-[500px] rounded-full opacity-20"
      style="background: radial-gradient(circle, hsl(var(--secondary) / 0.2) 0%, transparent 70%);"
    />

    <!-- Floating Dots (lg only) -->
    <div class="hidden lg:block">
      <div
        class="absolute w-2 h-2 rounded-full bg-primary/30 animate-float"
        style="left: 15%; top: 20%; animation-duration: 4s; animation-delay: 0s;"
      />
      <div
        class="absolute w-2 h-2 rounded-full bg-primary/30 animate-float"
        style="left: 30%; top: 45%; animation-duration: 5s; animation-delay: 0.5s;"
      />
      <div
        class="absolute w-2 h-2 rounded-full bg-primary/30 animate-float"
        style="left: 45%; top: 70%; animation-duration: 6s; animation-delay: 1s;"
      />
      <div
        class="absolute w-2 h-2 rounded-full bg-primary/30 animate-float"
        style="left: 60%; top: 20%; animation-duration: 7s; animation-delay: 1.5s;"
      />
      <div
        class="absolute w-2 h-2 rounded-full bg-primary/30 animate-float"
        style="left: 75%; top: 45%; animation-duration: 8s; animation-delay: 2s;"
      />
      <div
        class="absolute w-2 h-2 rounded-full bg-primary/30 animate-float"
        style="left: 90%; top: 70%; animation-duration: 9s; animation-delay: 2.5s;"
      />
    </div>
  </div>

  <div class="max-w-4xl mx-auto text-center relative z-10">
    <!-- Pre-headline -->
    <p class="text-muted-foreground text-sm mb-6 animate-fade-in">
      Für Personaldienstleister &amp; Recruiting-Agenturen
    </p>

    <!-- Main Headline -->
    <h1 class="text-4xl md:text-6xl lg:text-7xl font-bold mb-2 animate-fade-in-up">
      <span class="text-secondary">200k Upfront Fee. +300% Sales-Output.</span>
    </h1>
    <p class="text-4xl md:text-6xl lg:text-7xl font-bold mb-6 animate-fade-in-up animation-delay-100">
      <span class="gradient-text">Alles automatisiert.</span>
    </p>

    <!-- Subheadline -->
    <p class="text-lg md:text-xl text-muted-foreground mb-8 animate-fade-in-up animation-delay-200">
      Wie Recruiting-Agenturen mit OffenBoost ihre Sales-Pipeline automatisieren und mehr Aufträge gewinnen.
    </p>

    <!-- CTA Button -->
    <div class="animate-fade-in-up animation-delay-300">
      <a
        href="/termin"
        class="inline-flex items-center justify-center gap-2 font-medium bg-primary text-primary-foreground shadow hover:bg-primary/90 h-12 rounded-full px-8 text-base transition-colors"
      >
        Erstgespräch buchen
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
      <p class="text-sm text-muted-foreground mt-3">
        Kostenlos &amp; unverbindlich
      </p>
    </div>
  </div>
</section>
