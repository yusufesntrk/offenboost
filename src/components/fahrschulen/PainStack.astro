---
const painPoints = [
  {
    question: "80% deiner Schüler kommen über Empfehlungen — und du hoffst, dass das so bleibt?",
    icon: "users",
  },
  {
    question: "Meta Ads ausprobiert, Budget verbrannt, keine Anmeldungen bekommen?",
    icon: "flame",
  },
  {
    question: "Jüngere Fahrschulen schnappen dir mit Instagram & TikTok die Schüler weg?",
    icon: "trending-down",
  },
];
---

<section class="py-16 md:py-24 px-4 md:px-8">
  <div class="max-w-5xl mx-auto">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <p class="text-primary font-medium mb-4">Kommt dir das bekannt vor?</p>
    </div>

    <!-- Pain Point Cards -->
    <div class="grid md:grid-cols-3 gap-6">
      {painPoints.map((pain, index) => (
        <div
          class="feature-card text-center animate-fade-in-up"
          style={`animation-delay: ${index * 150}ms`}
        >
          <!-- Icon Container -->
          <div class="w-14 h-14 rounded-2xl bg-destructive/10 flex items-center justify-center mx-auto mb-4">
            {pain.icon === "users" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-destructive">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
                <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
                <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
              </svg>
            )}
            {pain.icon === "flame" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-destructive">
                <path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>
              </svg>
            )}
            {pain.icon === "trending-down" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-destructive">
                <polyline points="22 17 13.5 8.5 8.5 13.5 2 7"/>
                <polyline points="16 17 22 17 22 11"/>
              </svg>
            )}
          </div>

          <!-- Question Text -->
          <p class="text-lg font-semibold text-foreground">
            {pain.question}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
