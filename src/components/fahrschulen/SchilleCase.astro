---
---

<section class="bg-secondary text-secondary-foreground py-16 md:py-24 px-4 md:px-8">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="text-center mb-12">
      <p class="text-primary font-medium mb-4">Case Study</p>
      <h2 class="text-3xl md:text-4xl font-bold text-white tracking-tight">
        Fahrschule Schille, Stuttgart
      </h2>
    </div>

    <!-- Content Grid -->
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- LEFT: Image + Logo -->
      <div>
        <div class="relative rounded-2xl overflow-hidden">
          <img
            src="/testimonials/thomas-schille.png"
            alt="Thomas Schille, Inhaber Fahrschule Schille"
            class="w-full h-auto rounded-2xl"
            loading="lazy"
          />
        </div>
        <div class="flex items-center gap-3 mt-4">
          <img
            src="/logos/fahrschule-schille.png"
            alt="Fahrschule Schille Logo"
            class="h-8 w-auto opacity-80"
            loading="lazy"
          />
          <span class="text-sm text-secondary-foreground/70">Thomas Schille, Inhaber</span>
        </div>
      </div>

      <!-- RIGHT: Content -->
      <div>
        <!-- Vorher -->
        <div class="rounded-xl p-5 bg-white/5 border border-white/10 mb-4">
          <p class="text-xs font-medium uppercase tracking-wider text-destructive mb-2">Vorher</p>
          <ul class="text-secondary-foreground/80 text-sm list-disc pl-4 space-y-1">
            <li>Schüler nur über Mundpropaganda</li>
            <li>Keine Online-Präsenz, keine digitale Akquise</li>
            <li>Fahrlehrer-Mangel bremst Wachstum</li>
          </ul>
        </div>

        <!-- Nachher -->
        <div class="rounded-xl p-5 bg-primary/10 border border-primary/20 mb-6">
          <p class="text-xs font-medium uppercase tracking-wider text-primary mb-2">Nachher</p>
          <ul class="text-secondary-foreground/90 text-sm font-medium list-disc pl-4 space-y-1">
            <li>50 neue Fahrschüler in nur einem Monat</li>
            <li>175.000€ Umsatz generiert</li>
            <li>Neue Fahrlehrer trotz Fachkräftemangel gewonnen</li>
          </ul>
        </div>

        <!-- Metric Badge -->
        <div class="mb-6">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-primary/20 text-primary font-bold">
            ROI 10x &#8593;
          </span>
        </div>

        <!-- Quote -->
        <blockquote class="text-lg text-secondary-foreground/90 italic border-l-4 border-primary pl-4">
          50 neue Fahrschüler in einem Monat – das sind über 175.000€ Umsatz. OffenBoost hat uns zur Top-Fahrschule in Stuttgart gemacht.
          <cite class="block mt-2 text-sm text-secondary-foreground/60 not-italic">— Thomas Schille, Inhaber</cite>
        </blockquote>
      </div>
    </div>
  </div>
</section>
